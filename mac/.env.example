# Copy to mac/.env and fill in values. Never commit .env to git.

# Dashboard password — required for public access via Cloudflare tunnel
KEEPSAKE_DASHBOARD_PASSWORD=your-password-here

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
KEEPSAKE_SESSION_SECRET=change-me-to-random-hex-string

# URL prefix for dashboard routes (must match Cloudflare tunnel path)
KEEPSAKE_URL_PREFIX=/monitor

# Shared secret for Mac→Pi reload signal
KEEPSAKE_RELOAD_SECRET=another-random-secret

# NOAA Climate Data API token (optional — skip if not using NOAA data)
# Get free token at: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_TOKEN=

# Dashboard port (default 8080)
KEEPSAKE_DASHBOARD_PORT=8080
