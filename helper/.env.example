# helper/.env.example
# Copy to helper/.env and fill in values. Never commit .env to git.

# Required for online (tunnel) mode. Leave unset for LAN-only mode.
KEEPSAKE_URL_PREFIX=/monitor

# Required when KEEPSAKE_URL_PREFIX is set. 16+ chars recommended.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
KEEPSAKE_DASHBOARD_PASSWORD=set-a-strong-password-here

# Session signing key. Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
KEEPSAKE_SESSION_SECRET=generate-with-secrets-token-hex-32

# Timezone for display (default: Asia/Seoul)
KEEPSAKE_TIMEZONE=Asia/Seoul
